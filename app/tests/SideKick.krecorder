<body>
<table cellpadding="1" cellspacing="1" border="1">
<thead>
<tr><td rowspan="1" colspan="3" data-tags="">TP-01 Prijava sa pogresnom lozinkom</td></tr>
</thead>
<tbody>
<tr><td>open</td><td>http://127.0.0.1:8000/<datalist><option>http://127.0.0.1:8000/</option></datalist></td><td></td></tr>
<tr><td>click</td><td>xpath=//a[contains(text(),'Login')]<datalist><option>xpath=//a[contains(text(),'Login')]</option><option>xpath=(.//*[normalize-space(text()) and normalize-space(.)='Start saving research in one place.'])[1]/following::a[1]</option><option>xpath=(.//*[normalize-space(text()) and normalize-space(.)='Register'])[1]/following::a[1]</option><option>xpath=(.//*[normalize-space(text()) and normalize-space(.)='Register'])[2]/preceding::a[1]</option><option>xpath=(.//*[normalize-space(text()) and normalize-space(.)='Katalon Recorder is recording ...'])[1]/preceding::a[3]</option><option>xpath=//div/div/a</option><option>css=a.button.onboarding-action.onboarding-action--primary</option></datalist></td><td></td></tr>
<tr><td>click</td><td>name=email<datalist><option>name=email</option><option>xpath=//input[@name='email']</option><option>xpath=//label/input</option><option>css=input[name="email"]</option></datalist></td><td></td></tr>
<tr><td>type</td><td>name=email<datalist><option>name=email</option><option>xpath=//input[@name='email']</option><option>xpath=//label/input</option><option>css=input[name="email"]</option></datalist></td><td>petar@example.com</td></tr>
<tr><td>click</td><td>name=password<datalist><option>name=password</option><option>xpath=//input[@name='password']</option><option>xpath=//label[2]/input</option><option>css=input[name="password"]</option></datalist></td><td></td></tr>
<tr><td>type</td><td>name=password<datalist><option>name=password</option><option>xpath=//input[@name='password']</option><option>xpath=//label[2]/input</option><option>css=input[name="password"]</option></datalist></td><td>sdas123</td></tr>
<tr><td>click</td><td>xpath=//button[@type='submit']<datalist><option>xpath=//button[@type='submit']</option><option>xpath=(.//*[normalize-space(text()) and normalize-space(.)='Password'])[1]/following::button[1]</option><option>xpath=(.//*[normalize-space(text()) and normalize-space(.)='Email'])[1]/following::button[1]</option><option>xpath=(.//*[normalize-space(text()) and normalize-space(.)='Register'])[3]/preceding::button[1]</option><option>xpath=(.//*[normalize-space(text()) and normalize-space(.)='Katalon Recorder is recording ...'])[1]/preceding::button[1]</option><option>xpath=//form/div/button</option><option>css=button.button.auth-modal-button.auth-modal-button--primary</option></datalist></td><td></td></tr>
<tr><td>assertText</td><td>xpath=(.//*[normalize-space(text()) and normalize-space(.)='Login'])[3]/following::p[2]<datalist><option>xpath=(.//*[normalize-space(text()) and normalize-space(.)='Login'])[3]/following::p[2]</option><option>xpath=(.//*[normalize-space(text()) and normalize-space(.)='Register'])[2]/following::p[2]</option><option>xpath=(.//*[normalize-space(text()) and normalize-space(.)='Email'])[1]/preceding::p[1]</option><option>xpath=(.//*[normalize-space(text()) and normalize-space(.)='Password'])[1]/preceding::p[1]</option><option>xpath=//*/text()[normalize-space(.)='Wrong email or password.']/parent::*</option><option>xpath=//form/div/p</option><option>css=p.mock-login-feedback.error</option></datalist></td><td>Wrong email or password.</td></tr>
</tbody></table>
